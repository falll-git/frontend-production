NEXT_PUBLIC_API_URL=https://ruwangarsip.com/api

# Generate once on server: openssl rand -base64 32
# Keep this value stable across build/start and every PM2 instance.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Optional but recommended per deploy, for example git commit hash.
# Helps Next.js handle version skew by forcing a full reload for older clients.
NEXT_DEPLOYMENT_ID=
